# Local development only — copy to .streamlit/secrets.toml (gitignored).
# Streamlit-in-Snowflake injects its own session; this file is never deployed.
#
# Key-pair auth (recommended; password auth also works with `password = "..."`):
[connections.snowflake]
account = "<org>-<account>"          # e.g. ALFAINS-PROD1
user = "<your_user>"
private_key_file = "~/.ssh/snowflake_key.p8"
role = "OVERWATCH_MONITOR"           # or OVERWATCH_OPERATOR for action testing
warehouse = "WH_ALFA_OVERWATCH"
database = "DBA_MAINT_DB"
schema = "OVERWATCH"
client_session_keep_alive = true
